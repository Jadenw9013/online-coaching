# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/app/generated/prisma

# Claude Code (local-only settings)
.claude/settings.local.json

# Ruflo runtime data (generated, not committed)
.claude-flow/data/
.claude-flow/logs/
.claude-flow/sessions/

node_modules
.next
dist
build
coverage

# Expo / React Native
android
ios
.expo
.expo-shared

apps/mobile/android
apps/mobile/ios
# clerk configuration (can include secrets)
/.clerk/

# Additional logs and outputs to ignore
*.log
*-out*.txt
*error*.txt
lint-out*.txt
ts_errors*.txt
typescript-errors.txt
errors.txt

# Graphify (knowledge graph output)
graphify-out/
.graphifyignore

# Antigravity agent config (local-only)
.agent/

