{
  "hooks": {},
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npx prisma *)",
      "Bash(npx playwright *)",
      "Bash(npx tsx *)",
      "Bash(pnpm *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "claudeFlow": {
    "version": "3.0.0",
    "enabled": false,
    "platform": {
      "os": "macos",
      "arch": "arm64",
      "shell": "zsh"
    }
  }
}
