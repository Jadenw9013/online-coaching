generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  COACH
  CLIENT
}

enum IntakeStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum CheckInStatus {
  SUBMITTED
  REVIEWED
}

enum NotificationType {
  MEAL_PLAN_UPDATE
  CHECKIN_REMINDER
}

enum ReminderStage {
  PRE_DUE
  OVERDUE
}

model User {
  id         String   @id @default(cuid())
  clerkId    String   @unique
  email      String   @unique
  firstName  String?
  lastName   String?
  profilePhotoPath String?
  clientBio        String?  @db.Text
  fitnessGoal      String?
  activeRole Role     @default(CLIENT) @map("role")
  isCoach    Boolean  @default(false)
  isClient   Boolean  @default(true)
  phoneNumber           String?
  smsOptIn              Boolean  @default(false)
  smsMealPlanUpdates    Boolean  @default(false)
  smsDailyCheckInReminder Boolean @default(false)
  smsCoachMessages      Boolean  @default(false)
  smsCheckInFeedback    Boolean  @default(false)
  smsCheckInReminderTime String  @default("19:00")
  smsClientCheckIns     Boolean  @default(false)
  smsMissedCheckInAlerts Boolean @default(false)
  smsClientMessages     Boolean  @default(false)
  smsNewClientSignups   Boolean  @default(false)
  smsMissedCheckInAlertTime String @default("21:00")
  emailCheckInReminders  Boolean @default(true)
  emailMealPlanUpdates   Boolean @default(true)
  emailCoachMessages     Boolean @default(true)
  emailClientCheckIns    Boolean @default(true)
  emailClientMessages    Boolean @default(true)
  emailCoachingRequests  Boolean @default(true)
  defaultNotifyOnPublish Boolean @default(true)
  checkInDaysOfWeek     Int[]   @default([1])   // 0=Sun..6=Sat. Default: Monday
  cadenceConfig         Json?   // CadenceConfig object (null = legacy checkInDaysOfWeek)
  timezone              String  @default("America/New_York")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  coachAssignments  CoachClient[] @relation("Coach")
  clientAssignments CoachClient[] @relation("Client")
  checkIns          CheckIn[]
  clientMessages    Message[]     @relation("ClientMessages")
  sentMessages      Message[]     @relation("SentMessages")
  macroTargets      MacroTarget[] @relation("MacroTargets")
  mealPlans         MealPlan[]    @relation("MealPlans")
  foodLibrary       FoodLibraryItem[] @relation("FoodLibrary")
  coachUploads      MealPlanUpload[] @relation("CoachUploads")
  clientUploads     MealPlanUpload[] @relation("ClientUploads")
  notificationLogs  NotificationLog[]
  checkInTemplates  CheckInTemplate[] @relation("CheckInTemplates")
  trainingPrograms  TrainingProgram[] @relation("TrainingPrograms")
  trainingTemplates TrainingTemplate[] @relation("TrainingTemplates")
  workoutImports    WorkoutImport[]    @relation("WorkoutImports")
  coachProfile      CoachProfile?      @relation("MarketplaceProfile")
  prospectRequests  CoachingRequest[]  @relation("ProspectRequests")
  planSnippets      PlanSnippet[]      @relation("PlanSnippets")
  
  onboardingForm     OnboardingForm?     @relation("CoachOnboardingForm")
  onboardingResponse OnboardingResponse? @relation("ClientOnboardingResponse")

  intakesSent    ClientIntake[] @relation("CoachIntakes")
  intakeReceived ClientIntake?  @relation("ClientIntakes")

  dailyAdherences DailyAdherence[] @relation("DailyAdherences")
  exerciseResults  ExerciseResult[] @relation("ExerciseResults")

  testimonialsByCoach  Testimonial[] @relation("CoachTestimonials")
  testimonialsByClient Testimonial[] @relation("ClientTestimonials")
  savedCoaches         SavedCoach[]  @relation("UserSavedCoaches")

  clientInvitesSent    ClientInvite[]       @relation("CoachInvites")
  consultationMeetings ConsultationMeeting[] @relation("CoachMeetings")
  coachSettings        CoachSettings?        @relation("CoachSettings")

  teamId   String? @map("team_id")
  teamRole String? @map("team_role")
  team     Team?   @relation(fields: [teamId], references: [id])

  intakeFormTemplate IntakeFormTemplate?
  coachDocuments     CoachDocument[]
}

model IntakeFormTemplate {
  id        String   @id @default(cuid())
  coachId   String   @unique
  coach     User     @relation(fields: [coachId], references: [id], onDelete: Cascade)
  sections  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CoachClient {
  id         String   @id @default(cuid())
  coachId    String
  clientId   String
  coachNotes String?  @db.Text
  checkInDaysOfWeekOverride Int[]  @default([])  // empty = use coach default
  cadenceConfig             Json?  // CadenceConfig override (null = inherit coach default)
  adherenceEnabled          Boolean @default(false)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  coach  User @relation("Coach", fields: [coachId], references: [id])
  client User @relation("Client", fields: [clientId], references: [id])

  @@unique([coachId, clientId])
  @@index([coachId])
  @@index([clientId])
}

// ── Teams ────────────────────────────────────────────────────────────────────

model Team {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logoPath    String?
  description String?
  createdAt   DateTime @default(now())

  members User[]
  invites TeamInvite[]
}

model TeamInvite {
  id          String       @id @default(cuid())
  teamId      String
  inviteToken String       @unique @default(cuid())
  status      InviteStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  expiresAt   DateTime

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([inviteToken])
}

model CheckInTemplate {
  id        String   @id @default(cuid())
  coachId   String
  name      String
  isDefault Boolean  @default(false)
  version   Int      @default(1)
  questions Json     // Array of question objects (see lib/validations/check-in-template.ts)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  coach    User      @relation("CheckInTemplates", fields: [coachId], references: [id])
  checkIns CheckIn[]

  @@index([coachId])
}

model CheckIn {
  id         String   @id @default(cuid())
  clientId   String
  weekOf     DateTime
  weight     Float?
  bodyFatPct Float?
  status          CheckInStatus @default(SUBMITTED)
  dietCompliance  Int?
  energyLevel     Int?
  notes           String?  @db.Text
  deletedAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt  DateTime @updatedAt

  isPrimary       Boolean  @default(true)
  submittedAt     DateTime @default(now())
  localDate       String   @default("")
  timezone        String   @default("America/Los_Angeles")
  periodStartDate String   @default("")  // "YYYY-MM-DD" start of schedule-defined period
  periodEndDate   String   @default("")  // "YYYY-MM-DD" next scheduled day (exclusive end)

  templateId       String?
  templateSnapshot Json?     // Frozen copy of template.questions at submission time
  customResponses  Json?     // Answers to custom template questions

  client   User              @relation(fields: [clientId], references: [id])
  template CheckInTemplate?  @relation(fields: [templateId], references: [id])
  photos   CheckInPhoto[]

  @@index([clientId, weekOf])
  @@index([clientId, submittedAt])
  @@index([clientId, localDate])
  @@index([clientId, periodStartDate])
}

model MacroTarget {
  id        String   @id @default(cuid())
  clientId  String
  weekOf    DateTime
  calories  Int
  protein   Int
  carbs     Int
  fats      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client User @relation("MacroTargets", fields: [clientId], references: [id])

  @@unique([clientId, weekOf])
}

enum MealPlanStatus {
  DRAFT
  PUBLISHED
}

model MealPlan {
  id          String         @id @default(cuid())
  clientId    String
  weekOf      DateTime
  version     Int            @default(1)
  status      MealPlanStatus @default(DRAFT)
  planExtras  Json?          // PlanExtras object (see types/meal-plan-extras.ts)
  publishedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  client User           @relation("MealPlans", fields: [clientId], references: [id])
  items  MealPlanItem[]

  @@index([clientId, weekOf])
  @@index([clientId, status])
}

model MealPlanItem {
  id                 String  @id @default(cuid())
  mealPlanId         String
  mealName           String
  sortOrder          Int     @default(0)
  foodName           String
  quantity           String
  unit               String
  servingDescription String?
  calories           Int     @default(0)
  protein            Int     @default(0)
  carbs              Int     @default(0)
  fats               Int     @default(0)

  mealPlan MealPlan @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)

  @@index([mealPlanId])
}

model Message {
  id        String   @id @default(cuid())
  clientId  String
  weekOf    DateTime
  senderId  String
  body      String   @db.Text
  createdAt DateTime @default(now())

  client User @relation("ClientMessages", fields: [clientId], references: [id])
  sender User @relation("SentMessages", fields: [senderId], references: [id])

  @@index([clientId, weekOf])
  @@index([senderId])
}

model CheckInPhoto {
  id          String   @id @default(cuid())
  checkInId   String
  storagePath String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  checkIn CheckIn @relation(fields: [checkInId], references: [id], onDelete: Cascade)

  @@index([checkInId])
}

model FoodLibraryItem {
  id          String   @id @default(cuid())
  coachId     String
  name        String
  defaultUnit String   @default("serving")
  createdAt   DateTime @default(now())

  coach User @relation("FoodLibrary", fields: [coachId], references: [id])

  @@unique([coachId, name])
  @@index([coachId])
}

enum MealPlanUploadStatus {
  UPLOADED
  PROCESSING
  NEEDS_REVIEW
  IMPORTED
  FAILED
}

model MealPlanUpload {
  id               String               @id @default(cuid())
  coachId          String
  clientId         String
  storageBucket    String               @default("meal-plan-uploads")
  storagePath      String
  originalFilename String?
  mimeType         String?
  status           MealPlanUploadStatus @default(UPLOADED)
  errorMessage     String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  coach  User            @relation("CoachUploads", fields: [coachId], references: [id])
  client User            @relation("ClientUploads", fields: [clientId], references: [id])
  draft  MealPlanDraft?

  @@index([coachId])
  @@index([clientId])
}

model MealPlanDraft {
  id            String   @id @default(cuid())
  uploadId      String   @unique
  extractedText String?  @db.Text
  parsedJson    Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  upload MealPlanUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)
}

// ── Workout Plan Import ──────────────────────────────────────────────────────

enum WorkoutImportStatus {
  UPLOADED
  PROCESSING
  NEEDS_REVIEW
  IMPORTED
  FAILED
}

model WorkoutImport {
  id               String              @id @default(cuid())
  coachId          String
  clientId         String?
  storageBucket    String              @default("meal-plan-uploads")
  storagePath      String              @default("")
  originalFilename String?
  mimeType         String?
  status           WorkoutImportStatus @default(UPLOADED)
  errorMessage     String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  coach User               @relation("WorkoutImports", fields: [coachId], references: [id])
  draft WorkoutImportDraft?

  @@index([coachId])
}

model WorkoutImportDraft {
  id            String   @id @default(cuid())
  importId      String   @unique
  extractedText String?  @db.Text
  parsedJson    Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workoutImport WorkoutImport @relation(fields: [importId], references: [id], onDelete: Cascade)
}

// ── Training Templates (coach-owned, reusable) ──────────────────────────────

model TrainingTemplate {
  id          String   @id @default(cuid())
  coachId     String
  name        String
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  coach    User                   @relation("TrainingTemplates", fields: [coachId], references: [id])
  days     TrainingTemplateDay[]
  cardio   TrainingTemplateCardio?
  programs TrainingProgram[]       @relation("TemplateSource")

  @@index([coachId])
}

model TrainingTemplateDay {
  id          String   @id @default(cuid())
  templateId  String
  dayName     String
  description String?  @db.Text
  sortOrder   Int      @default(0)

  template  TrainingTemplate          @relation(fields: [templateId], references: [id], onDelete: Cascade)
  exercises TrainingTemplateExercise[]
  blocks    TrainingTemplateBlock[]

  @@index([templateId])
}

model TrainingTemplateBlock {
  id        String    @id @default(cuid())
  dayId     String
  type      BlockType @default(EXERCISE)
  title     String    @default("")
  content   String    @db.Text @default("")
  sortOrder Int       @default(0)

  day TrainingTemplateDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@index([dayId])
}

model TrainingTemplateExercise {
  id            String  @id @default(cuid())
  dayId         String
  name          String
  sets          Int     @default(3)
  reps          String  @default("10")
  intensityText String?
  notes         String? @db.Text
  sortOrder     Int     @default(0)

  day TrainingTemplateDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@index([dayId])
}

model TrainingTemplateCardio {
  id         String  @id @default(cuid())
  templateId String  @unique
  frequency  String?
  duration   String?
  modality   String?
  intensity  String?
  notes      String? @db.Text

  template TrainingTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

// ── Training Programs (client-specific, week-scoped) ────────────────────────

enum TrainingProgramStatus {
  DRAFT
  PUBLISHED
}

enum BlockType {
  EXERCISE
  ACTIVATION
  INSTRUCTION
  SUPERSET
  CARDIO
  OPTIONAL
}

model TrainingProgram {
  id               String                @id @default(cuid())
  clientId         String
  weekOf           DateTime
  status           TrainingProgramStatus @default(DRAFT)
  publishedAt      DateTime?
  templateSourceId String?
  weeklyFrequency  Int?
  clientNotes      String?               @db.Text
  injuries         String?               @db.Text
  equipment        String?               @db.Text
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  client         User                   @relation("TrainingPrograms", fields: [clientId], references: [id])
  templateSource TrainingTemplate?      @relation("TemplateSource", fields: [templateSourceId], references: [id])
  days           TrainingDay[]
  cardio         TrainingProgramCardio?

  @@index([clientId, weekOf])
  @@index([clientId, status])
}

model TrainingProgramCardio {
  id        String  @id @default(cuid())
  programId String  @unique
  frequency String?
  duration  String?
  modality  String?
  intensity String?
  notes     String? @db.Text

  program TrainingProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
}

model TrainingDay {
  id          String   @id @default(cuid())
  programId   String
  dayName     String
  description String?  @db.Text
  sortOrder   Int      @default(0)

  program   TrainingProgram    @relation(fields: [programId], references: [id], onDelete: Cascade)
  exercises TrainingExercise[]
  blocks    TrainingProgramBlock[]

  @@index([programId])
}

model TrainingProgramBlock {
  id        String    @id @default(cuid())
  dayId     String
  type      BlockType @default(EXERCISE)
  title     String    @default("")
  content   String    @db.Text @default("")
  sortOrder Int       @default(0)

  day TrainingDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@index([dayId])
}

model TrainingExercise {
  id            String  @id @default(cuid())
  dayId         String
  name          String
  sets          Int     @default(3)
  reps          String  @default("10")
  intensityText String?
  notes         String? @db.Text
  sortOrder     Int     @default(0)

  day TrainingDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@index([dayId])
}

model NotificationLog {
  id              String           @id @default(cuid())
  type            NotificationType
  clientId        String
  mealPlanId      String?
  windowStartDate DateTime?
  stage           ReminderStage?
  sentAt          DateTime         @default(now())
  metadata        Json?

  client User @relation(fields: [clientId], references: [id])

  @@unique([clientId, windowStartDate, type, stage], name: "reminder_dedupe")
  @@index([clientId, type])
}

// ── Marketplace ─────────────────────────────────────────────────────────────

model CoachProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  slug             String   @unique
  headline         String?  @db.Text
  bio              String?  @db.Text
  specialties      String[] @default([])
  pricing          String?
  acceptingClients Boolean  @default(true)
  isPublished      Boolean  @default(false)
  welcomeMessage   String?  @db.Text
  bannerPhotoPath  String?
  experience       String?  @db.Text
  certifications   String?  @db.Text
  coachingType     String?              // "online" | "in-person" | "hybrid"
  location         String?              // display string (freeform)
  city             String?              // structured city for filter/matching
  state            String?              // state/province/region for filter/matching
  serviceTier      String?              // "training-only" | "nutrition-only" | "full-coaching"
  gymName          String?
  yearsCoaching    Int?
  phoneNumber      String?              // optional contact phone shown on public profile
  services         String[] @default([])
  clientGoals      String[] @default([])
  clientTypes      String[] @default([])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User              @relation("MarketplaceProfile", fields: [userId], references: [id], onDelete: Cascade)
  requests         CoachingRequest[]
  portfolioItems   PortfolioItem[]
  savedBy          SavedCoach[]
}

model PortfolioItem {
  id             String       @id @default(cuid())
  coachProfileId String
  title          String
  result         String?      @db.Text
  description    String?      @db.Text
  category       String?
  mediaPath      String?
  mediaType      String?      // "image" or "video"
  sortOrder      Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  coachProfile   CoachProfile @relation(fields: [coachProfileId], references: [id], onDelete: Cascade)

  @@index([coachProfileId])
}

model Testimonial {
  id           String   @id @default(cuid())
  coachId      String
  clientId     String
  rating       Int                         // 1–5
  reviewText   String?  @db.Text           // optional — star-only reviews permitted
  anonymous    Boolean  @default(false)    // hide client name on public profile
  images       String[] @default([])       // up to 4 Supabase storage paths
  status       String   @default("published") // "published" | "hidden" | "flagged"
  reportReason String?                     // reason text when coach flags a review
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  coach  User @relation("CoachTestimonials", fields: [coachId], references: [id])
  client User @relation("ClientTestimonials", fields: [clientId], references: [id])

  @@unique([coachId, clientId])
  @@index([coachId])
}

model SavedCoach {
  id             String       @id @default(cuid())
  userId         String
  coachProfileId String
  createdAt      DateTime     @default(now())

  user         User         @relation("UserSavedCoaches", fields: [userId], references: [id], onDelete: Cascade)
  coachProfile CoachProfile @relation(fields: [coachProfileId], references: [id], onDelete: Cascade)

  @@unique([userId, coachProfileId])
  @@index([userId])
}

enum RequestStatus {
  PENDING
  CONTACTED
  CALL_SCHEDULED
  ACCEPTED
  DECLINED
  APPROVED      // legacy — kept for backward compat
  REJECTED      // legacy — kept for backward compat
  WAITLISTED
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

enum ConsultationStage {
  PENDING
  CONSULTATION_SCHEDULED
  CONSULTATION_DONE
  INTAKE_SENT
  INTAKE_SUBMITTED
  FORMS_SENT
  FORMS_SIGNED
  ACTIVE
  DECLINED
}

enum CoachDocumentType {
  TEXT
  FILE
}

enum LeadSource {
  MARKETPLACE
  EXTERNAL
}

enum FormSubmissionStatus {
  DRAFT
  READY_TO_SEND
  SENT
  SIGNED
}

enum SignatureType {
  TYPED
  DRAWN
}

model CoachingRequest {
  id              String   @id @default(cuid())
  coachProfileId  String
  prospectName    String
  prospectEmail   String
  prospectPhone       String?
  prospectEmailAddr   String?
  intakeAnswers   Json
  status          RequestStatus @default(PENDING)
  consultationStage   ConsultationStage @default(PENDING)
  consultationDate    DateTime?
  source              LeadSource @default(MARKETPLACE)
  sourceDetail        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  prospectId      String?  // Optional User ID if the prospect has an account
  prospect        User?    @relation("ProspectRequests", fields: [prospectId], references: [id], onDelete: SetNull)

  inviteLastSentAt DateTime?     // Last time invite/sign-up email was sent
  inviteSendCount  Int      @default(0) // Total invite sends (initial approval + resends)

  formsToken          String?  @unique
  formsTokenExpiresAt DateTime?
  formsSentAt         DateTime?
  formsSignedAt       DateTime?

  coachProfile         CoachProfile          @relation(fields: [coachProfileId], references: [id], onDelete: Cascade)
  consultationMeeting  ConsultationMeeting?
  formSubmission       ClientFormSubmission?
  signature            ClientFormSignature?
  intakePacket         IntakePacket?

  @@index([coachProfileId])
  @@index([status])
  @@index([consultationStage])
  @@index([prospectId])
  @@index([prospectEmail, status])
}

model ClientFormSubmission {
  id                String               @id @default(cuid())
  coachingRequestId String               @unique
  coachingRequest   CoachingRequest      @relation(fields: [coachingRequestId], references: [id], onDelete: Cascade)
  answers           Json
  status            FormSubmissionStatus @default(DRAFT)
  completedAt       DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
}

model ClientFormSignature {
  id                String          @id @default(cuid())
  coachingRequestId String          @unique
  coachingRequest   CoachingRequest @relation(fields: [coachingRequestId], references: [id], onDelete: Cascade)
  signatureType     SignatureType
  signatureValue    String          @db.Text
  signedAt          DateTime        @default(now())
  ipAddress         String?
  userAgent         String?
  createdAt         DateTime        @default(now())
}

model ClientInvite {
  id          String       @id @default(cuid())
  coachId     String
  email       String
  name        String
  inviteToken String       @unique @default(cuid())
  status      InviteStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  expiresAt   DateTime

  coach User @relation("CoachInvites", fields: [coachId], references: [id])

  @@index([coachId])
  @@index([inviteToken])
}

model ConsultationMeeting {
  id            String    @id @default(cuid())
  coachId       String
  requestId     String    @unique
  meetingLink   String?
  scheduledTime DateTime?
  notes         String?   @db.Text
  createdAt     DateTime  @default(now())

  coach   User            @relation("CoachMeetings", fields: [coachId], references: [id])
  request CoachingRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([coachId])
}

model CoachSettings {
  id                          String  @id @default(cuid())
  coachId                     String  @unique
  acceptRequestsAutomatically Boolean @default(false)
  requireConsultation         Boolean @default(false)
  allowDirectInvites          Boolean @default(true)
  allowMarketplaceRequests    Boolean @default(true)

  coach User @relation("CoachSettings", fields: [coachId], references: [id], onDelete: Cascade)
}

model OnboardingForm {
  id        String   @id @default(cuid())
  coachId   String   @unique
  questions Json     // Array of standard question objects (id, type, label, required)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  coach     User                 @relation("CoachOnboardingForm", fields: [coachId], references: [id])
  responses OnboardingResponse[]

  @@index([coachId])
}

model OnboardingResponse {
  id        String   @id @default(cuid())
  clientId  String   @unique
  coachId   String
  formId    String
  answers   Json     // Array of { questionId, answer }
  createdAt DateTime @default(now())

  client User           @relation("ClientOnboardingResponse", fields: [clientId], references: [id])
  form   OnboardingForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([coachId])
  @@index([formId])
}

// ── Client Intake Questionnaire ──────────────────────────────────────────────
//
// Separate from the generic coach-owned OnboardingForm/OnboardingResponse system.
// This is a structured, pre-defined intake with specific health/fitness fields
// that the coach can optionally send to newly added clients.
//
// Data model rationale: bodyweightLbs is stored here (not in CheckIn) to avoid
// corrupting coach inbox status signals. The coach profile page surfaces it
// directly when no real check-ins exist yet.

model ClientIntake {
  id          String       @id @default(cuid())
  coachId     String
  clientId    String       @unique // one active intake per client
  status      IntakeStatus @default(PENDING)
  sentAt      DateTime     @default(now())
  startedAt   DateTime?
  completedAt DateTime?

  // Structured intake answers (populated when status = COMPLETED)
  bodyweightLbs       Float?
  heightInches        Float?
  ageYears            Int?
  gender              String?
  primaryGoal         String?
  targetTimeline      String?
  injuries            String?  @db.Text
  dietaryRestrictions String?
  dietaryPreferences  String?  @db.Text
  currentDiet         String?  @db.Text
  trainingExperience  String?
  trainingDaysPerWeek Int?
  gymAccess           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  coach  User @relation("CoachIntakes",  fields: [coachId],  references: [id])
  client User @relation("ClientIntakes", fields: [clientId], references: [id])

  @@index([coachId])
  @@index([clientId])
}

// ── Plan Snippets (reusable meal plan section templates) ────────────────────

model PlanSnippet {
  id        String   @id @default(cuid())
  coachId   String
  type      String   // "supplements" | "override" | "rules" | "allowances"
  name      String
  payload   Json     // section data (Supplement[], DayOverride, Rule[], Allowance[])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  coach User @relation("PlanSnippets", fields: [coachId], references: [id])

  @@index([coachId, type])
}

// ── Daily Adherence Tracking ────────────────────────────────────────────────

model DailyAdherence {
  id                 String   @id @default(cuid())
  clientId           String
  date               String   // YYYY-MM-DD client local date
  weekOf             DateTime // normalized Monday UTC (for weekly aggregation)
  workoutCompleted   Boolean  @default(false)
  workoutCompletedAt DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  client User               @relation("DailyAdherences", fields: [clientId], references: [id])
  meals  DailyMealCheckoff[]
  exercises ExerciseCheckoff[]

  @@unique([clientId, date])
  @@index([clientId])
}

model DailyMealCheckoff {
  id               String   @id @default(cuid())
  dailyAdherenceId String
  mealNameSnapshot String   // snapshot of mealName — stable even if coach later edits plan
  displayOrder     Int      @default(0)
  completed        Boolean  @default(false)
  completedAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  dailyAdherence DailyAdherence @relation(fields: [dailyAdherenceId], references: [id], onDelete: Cascade)

  @@unique([dailyAdherenceId, mealNameSnapshot])
  @@index([dailyAdherenceId])
}

model ExerciseCheckoff {
  id               String   @id @default(cuid())
  dailyAdherenceId String
  dayLabel         String   // snapshot: "Day 1 — Chest"
  exerciseName     String   // snapshot: "Incline Press"
  exerciseOrder    Int      @default(0) // position within the day
  completed        Boolean  @default(false)
  completedAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  dailyAdherence DailyAdherence @relation(fields: [dailyAdherenceId], references: [id], onDelete: Cascade)

  @@unique([dailyAdherenceId, dayLabel, exerciseOrder])
  @@index([dailyAdherenceId])
}

// ── Exercise Progress Tracking ──────────────────────────────────────────────

model ExerciseResult {
  id           String   @id @default(cuid())
  clientId     String
  exerciseName String   // snapshot: "Incline Press"
  programDay   String   // snapshot: "Day 1 — Chest"
  weekOf       DateTime // normalizeToMonday()
  weight       Float
  reps         Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  client User @relation("ExerciseResults", fields: [clientId], references: [id])

  @@unique([clientId, exerciseName, programDay, weekOf])
  @@index([clientId])
}

model CoachDocument {
  id        String            @id @default(cuid())
  coachId   String
  coach     User              @relation(fields: [coachId], references: [id])
  title     String
  type      CoachDocumentType
  content   String?           @db.Text
  filePath  String?
  fileType  String?
  fileName  String?
  isActive  Boolean           @default(true)
  sortOrder Int               @default(0)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  packetDocuments IntakePacketDocument[]
  signatures      DocumentSignature[]

  @@index([coachId])
}

model IntakePacket {
  id                String              @id @default(cuid())
  coachingRequestId String              @unique
  coachingRequest   CoachingRequest     @relation(fields: [coachingRequestId], references: [id])
  token             String              @unique
  tokenExpiresAt    DateTime
  sentAt            DateTime            @default(now())
  submittedAt       DateTime?
  formAnswers       Json?
  coachNotes        String?             @db.Text
  documents         IntakePacketDocument[]
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
}

model IntakePacketDocument {
  id              String        @id @default(cuid())
  intakePacketId  String
  intakePacket    IntakePacket  @relation(fields: [intakePacketId], references: [id])
  coachDocumentId String
  coachDocument   CoachDocument @relation(fields: [coachDocumentId], references: [id])
  sortOrder               Int           @default(0)
  signature               DocumentSignature?
  uploadedSignedFilePath  String?
  uploadedSignedFileName  String?
  uploadedSignedAt        DateTime?

  @@index([intakePacketId])
}

model DocumentSignature {
  id                     String               @id @default(cuid())
  intakePacketDocumentId String               @unique
  intakePacketDocument   IntakePacketDocument @relation(fields: [intakePacketDocumentId], references: [id])
  coachDocumentId        String
  coachDocument          CoachDocument        @relation(fields: [coachDocumentId], references: [id])
  signatureType          SignatureType
  signatureValue         String               @db.Text
  signedAt               DateTime             @default(now())
  ipAddress              String?
  userAgent              String?
}
