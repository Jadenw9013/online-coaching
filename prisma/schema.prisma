generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  COACH
  CLIENT
}

enum CheckInStatus {
  SUBMITTED
  REVIEWED
}

enum NotificationType {
  MEAL_PLAN_UPDATE
  CHECKIN_REMINDER
}

enum ReminderStage {
  PRE_DUE
  OVERDUE
}

model User {
  id         String   @id @default(cuid())
  clerkId    String   @unique
  email      String   @unique
  firstName  String?
  lastName   String?
  profilePhotoPath String?
  clientBio        String?  @db.Text
  fitnessGoal      String?
  activeRole Role     @default(CLIENT) @map("role")
  isCoach    Boolean  @default(false)
  isClient   Boolean  @default(true)
  coachCode             String?  @unique
  phoneNumber           String?
  smsOptIn              Boolean  @default(false)
  smsMealPlanUpdates    Boolean  @default(false)
  smsDailyCheckInReminder Boolean @default(false)
  smsCoachMessages      Boolean  @default(false)
  smsCheckInFeedback    Boolean  @default(false)
  smsCheckInReminderTime String  @default("19:00")
  smsClientCheckIns     Boolean  @default(false)
  smsMissedCheckInAlerts Boolean @default(false)
  smsClientMessages     Boolean  @default(false)
  smsNewClientSignups   Boolean  @default(false)
  smsMissedCheckInAlertTime String @default("21:00")
  defaultNotifyOnPublish Boolean @default(true)
  checkInDaysOfWeek     Int[]   @default([1])   // 0=Sun..6=Sat. Default: Monday
  cadenceConfig         Json?   // CadenceConfig object (null = legacy checkInDaysOfWeek)
  timezone              String  @default("America/New_York")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  coachAssignments  CoachClient[] @relation("Coach")
  clientAssignments CoachClient[] @relation("Client")
  checkIns          CheckIn[]
  clientMessages    Message[]     @relation("ClientMessages")
  sentMessages      Message[]     @relation("SentMessages")
  macroTargets      MacroTarget[] @relation("MacroTargets")
  mealPlans         MealPlan[]    @relation("MealPlans")
  foodLibrary       FoodLibraryItem[] @relation("FoodLibrary")
  coachUploads      MealPlanUpload[] @relation("CoachUploads")
  clientUploads     MealPlanUpload[] @relation("ClientUploads")
  notificationLogs  NotificationLog[]
  checkInTemplates  CheckInTemplate[] @relation("CheckInTemplates")
  trainingPrograms  TrainingProgram[] @relation("TrainingPrograms")
  trainingTemplates TrainingTemplate[] @relation("TrainingTemplates")
  workoutImports    WorkoutImport[]    @relation("WorkoutImports")
  coachProfile      CoachProfile?      @relation("MarketplaceProfile")
  prospectRequests  CoachingRequest[]  @relation("ProspectRequests")
  
  onboardingForm     OnboardingForm?     @relation("CoachOnboardingForm")
  onboardingResponse OnboardingResponse? @relation("ClientOnboardingResponse")
}

model CoachClient {
  id         String   @id @default(cuid())
  coachId    String
  clientId   String
  coachNotes String?  @db.Text
  checkInDaysOfWeekOverride Int[]  @default([])  // empty = use coach default
  cadenceConfig             Json?  // CadenceConfig override (null = inherit coach default)
  createdAt  DateTime @default(now())

  coach  User @relation("Coach", fields: [coachId], references: [id])
  client User @relation("Client", fields: [clientId], references: [id])

  @@unique([coachId, clientId])
  @@index([coachId])
  @@index([clientId])
}

model CheckInTemplate {
  id        String   @id @default(cuid())
  coachId   String
  name      String
  isDefault Boolean  @default(false)
  version   Int      @default(1)
  questions Json     // Array of question objects (see lib/validations/check-in-template.ts)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  coach    User      @relation("CheckInTemplates", fields: [coachId], references: [id])
  checkIns CheckIn[]

  @@index([coachId])
}

model CheckIn {
  id         String   @id @default(cuid())
  clientId   String
  weekOf     DateTime
  weight     Float?
  bodyFatPct Float?
  status          CheckInStatus @default(SUBMITTED)
  dietCompliance  Int?
  energyLevel     Int?
  notes           String?  @db.Text
  deletedAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt  DateTime @updatedAt

  isPrimary       Boolean  @default(true)
  submittedAt     DateTime @default(now())
  localDate       String   @default("")
  timezone        String   @default("America/Los_Angeles")
  periodStartDate String   @default("")  // "YYYY-MM-DD" start of schedule-defined period
  periodEndDate   String   @default("")  // "YYYY-MM-DD" next scheduled day (exclusive end)

  templateId       String?
  templateSnapshot Json?     // Frozen copy of template.questions at submission time
  customResponses  Json?     // Answers to custom template questions

  client   User              @relation(fields: [clientId], references: [id])
  template CheckInTemplate?  @relation(fields: [templateId], references: [id])
  photos   CheckInPhoto[]

  @@index([clientId, weekOf])
  @@index([clientId, submittedAt])
  @@index([clientId, localDate])
  @@index([clientId, periodStartDate])
}

model MacroTarget {
  id        String   @id @default(cuid())
  clientId  String
  weekOf    DateTime
  calories  Int
  protein   Int
  carbs     Int
  fats      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client User @relation("MacroTargets", fields: [clientId], references: [id])

  @@unique([clientId, weekOf])
}

enum MealPlanStatus {
  DRAFT
  PUBLISHED
}

model MealPlan {
  id          String         @id @default(cuid())
  clientId    String
  weekOf      DateTime
  version     Int            @default(1)
  status      MealPlanStatus @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  client User           @relation("MealPlans", fields: [clientId], references: [id])
  items  MealPlanItem[]

  @@index([clientId, weekOf])
  @@index([clientId, status])
}

model MealPlanItem {
  id                 String  @id @default(cuid())
  mealPlanId         String
  mealName           String
  sortOrder          Int     @default(0)
  foodName           String
  quantity           String
  unit               String
  servingDescription String?
  calories           Int     @default(0)
  protein            Int     @default(0)
  carbs              Int     @default(0)
  fats               Int     @default(0)

  mealPlan MealPlan @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)

  @@index([mealPlanId])
}

model Message {
  id        String   @id @default(cuid())
  clientId  String
  weekOf    DateTime
  senderId  String
  body      String   @db.Text
  createdAt DateTime @default(now())

  client User @relation("ClientMessages", fields: [clientId], references: [id])
  sender User @relation("SentMessages", fields: [senderId], references: [id])

  @@index([clientId, weekOf])
  @@index([senderId])
}

model CheckInPhoto {
  id          String   @id @default(cuid())
  checkInId   String
  storagePath String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  checkIn CheckIn @relation(fields: [checkInId], references: [id], onDelete: Cascade)

  @@index([checkInId])
}

model FoodLibraryItem {
  id          String   @id @default(cuid())
  coachId     String
  name        String
  defaultUnit String   @default("serving")
  createdAt   DateTime @default(now())

  coach User @relation("FoodLibrary", fields: [coachId], references: [id])

  @@unique([coachId, name])
  @@index([coachId])
}

enum MealPlanUploadStatus {
  UPLOADED
  PROCESSING
  NEEDS_REVIEW
  IMPORTED
  FAILED
}

model MealPlanUpload {
  id               String               @id @default(cuid())
  coachId          String
  clientId         String
  storageBucket    String               @default("meal-plan-uploads")
  storagePath      String
  originalFilename String?
  mimeType         String?
  status           MealPlanUploadStatus @default(UPLOADED)
  errorMessage     String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  coach  User            @relation("CoachUploads", fields: [coachId], references: [id])
  client User            @relation("ClientUploads", fields: [clientId], references: [id])
  draft  MealPlanDraft?

  @@index([coachId])
  @@index([clientId])
}

model MealPlanDraft {
  id            String   @id @default(cuid())
  uploadId      String   @unique
  extractedText String?  @db.Text
  parsedJson    Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  upload MealPlanUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)
}

// ── Workout Plan Import ──────────────────────────────────────────────────────

enum WorkoutImportStatus {
  UPLOADED
  PROCESSING
  NEEDS_REVIEW
  IMPORTED
  FAILED
}

model WorkoutImport {
  id               String              @id @default(cuid())
  coachId          String
  clientId         String?
  storageBucket    String              @default("meal-plan-uploads")
  storagePath      String              @default("")
  originalFilename String?
  mimeType         String?
  status           WorkoutImportStatus @default(UPLOADED)
  errorMessage     String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  coach User               @relation("WorkoutImports", fields: [coachId], references: [id])
  draft WorkoutImportDraft?

  @@index([coachId])
}

model WorkoutImportDraft {
  id            String   @id @default(cuid())
  importId      String   @unique
  extractedText String?  @db.Text
  parsedJson    Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workoutImport WorkoutImport @relation(fields: [importId], references: [id], onDelete: Cascade)
}

// ── Training Templates (coach-owned, reusable) ──────────────────────────────

model TrainingTemplate {
  id          String   @id @default(cuid())
  coachId     String
  name        String
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  coach    User                   @relation("TrainingTemplates", fields: [coachId], references: [id])
  days     TrainingTemplateDay[]
  cardio   TrainingTemplateCardio?
  programs TrainingProgram[]       @relation("TemplateSource")

  @@index([coachId])
}

model TrainingTemplateDay {
  id          String   @id @default(cuid())
  templateId  String
  dayName     String
  description String?  @db.Text
  sortOrder   Int      @default(0)

  template  TrainingTemplate          @relation(fields: [templateId], references: [id], onDelete: Cascade)
  exercises TrainingTemplateExercise[]
  blocks    TrainingTemplateBlock[]

  @@index([templateId])
}

model TrainingTemplateBlock {
  id        String    @id @default(cuid())
  dayId     String
  type      BlockType @default(EXERCISE)
  title     String    @default("")
  content   String    @db.Text @default("")
  sortOrder Int       @default(0)

  day TrainingTemplateDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@index([dayId])
}

model TrainingTemplateExercise {
  id            String  @id @default(cuid())
  dayId         String
  name          String
  sets          Int     @default(3)
  reps          String  @default("10")
  intensityText String?
  notes         String? @db.Text
  sortOrder     Int     @default(0)

  day TrainingTemplateDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@index([dayId])
}

model TrainingTemplateCardio {
  id         String  @id @default(cuid())
  templateId String  @unique
  frequency  String?
  duration   String?
  modality   String?
  intensity  String?
  notes      String? @db.Text

  template TrainingTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

// ── Training Programs (client-specific, week-scoped) ────────────────────────

enum TrainingProgramStatus {
  DRAFT
  PUBLISHED
}

enum BlockType {
  EXERCISE
  ACTIVATION
  INSTRUCTION
  SUPERSET
  CARDIO
  OPTIONAL
}

model TrainingProgram {
  id               String                @id @default(cuid())
  clientId         String
  weekOf           DateTime
  status           TrainingProgramStatus @default(DRAFT)
  publishedAt      DateTime?
  templateSourceId String?
  weeklyFrequency  Int?
  clientNotes      String?               @db.Text
  injuries         String?               @db.Text
  equipment        String?               @db.Text
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  client         User                   @relation("TrainingPrograms", fields: [clientId], references: [id])
  templateSource TrainingTemplate?      @relation("TemplateSource", fields: [templateSourceId], references: [id])
  days           TrainingDay[]
  cardio         TrainingProgramCardio?

  @@index([clientId, weekOf])
  @@index([clientId, status])
}

model TrainingProgramCardio {
  id        String  @id @default(cuid())
  programId String  @unique
  frequency String?
  duration  String?
  modality  String?
  intensity String?
  notes     String? @db.Text

  program TrainingProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
}

model TrainingDay {
  id          String   @id @default(cuid())
  programId   String
  dayName     String
  description String?  @db.Text
  sortOrder   Int      @default(0)

  program   TrainingProgram    @relation(fields: [programId], references: [id], onDelete: Cascade)
  exercises TrainingExercise[]
  blocks    TrainingProgramBlock[]

  @@index([programId])
}

model TrainingProgramBlock {
  id        String    @id @default(cuid())
  dayId     String
  type      BlockType @default(EXERCISE)
  title     String    @default("")
  content   String    @db.Text @default("")
  sortOrder Int       @default(0)

  day TrainingDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@index([dayId])
}

model TrainingExercise {
  id            String  @id @default(cuid())
  dayId         String
  name          String
  sets          Int     @default(3)
  reps          String  @default("10")
  intensityText String?
  notes         String? @db.Text
  sortOrder     Int     @default(0)

  day TrainingDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@index([dayId])
}

model NotificationLog {
  id              String           @id @default(cuid())
  type            NotificationType
  clientId        String
  mealPlanId      String?
  windowStartDate DateTime?
  stage           ReminderStage?
  sentAt          DateTime         @default(now())
  metadata        Json?

  client User @relation(fields: [clientId], references: [id])

  @@unique([clientId, windowStartDate, type, stage], name: "reminder_dedupe")
  @@index([clientId, type])
}

// ── Marketplace ─────────────────────────────────────────────────────────────

model CoachProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  slug             String   @unique
  headline         String?  @db.Text
  bio              String?  @db.Text
  specialties      String[] @default([])
  pricing          String?
  acceptingClients Boolean  @default(true)
  isPublished      Boolean  @default(false)
  welcomeMessage   String?  @db.Text
  bannerPhotoPath  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User              @relation("MarketplaceProfile", fields: [userId], references: [id], onDelete: Cascade)
  requests         CoachingRequest[]
  portfolioItems   PortfolioItem[]
}

model PortfolioItem {
  id             String       @id @default(cuid())
  coachProfileId String
  title          String
  result         String?      @db.Text
  description    String?      @db.Text
  category       String?
  sortOrder      Int          @default(0)
  createdAt      DateTime     @default(now())

  coachProfile   CoachProfile @relation(fields: [coachProfileId], references: [id], onDelete: Cascade)

  @@index([coachProfileId])
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  WAITLISTED
}

model CoachingRequest {
  id              String   @id @default(cuid())
  coachProfileId  String
  prospectName    String
  prospectEmail   String
  intakeAnswers   Json
  status          RequestStatus @default(PENDING)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  prospectId      String?  // Optional User ID if the prospect has an account
  prospect        User?    @relation("ProspectRequests", fields: [prospectId], references: [id], onDelete: SetNull)

  inviteLastSentAt DateTime?     // Last time invite/sign-up email was sent
  inviteSendCount  Int      @default(0) // Total invite sends (initial approval + resends)

  coachProfile    CoachProfile @relation(fields: [coachProfileId], references: [id], onDelete: Cascade)

  @@index([coachProfileId])
  @@index([status])
  @@index([prospectId])
  @@index([prospectEmail, status])
}

model OnboardingForm {
  id        String   @id @default(cuid())
  coachId   String   @unique
  questions Json     // Array of standard question objects (id, type, label, required)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  coach     User                 @relation("CoachOnboardingForm", fields: [coachId], references: [id])
  responses OnboardingResponse[]

  @@index([coachId])
}

model OnboardingResponse {
  id        String   @id @default(cuid())
  clientId  String   @unique
  coachId   String
  formId    String
  answers   Json     // Array of { questionId, answer }
  createdAt DateTime @default(now())

  client User           @relation("ClientOnboardingResponse", fields: [clientId], references: [id])
  form   OnboardingForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([coachId])
  @@index([formId])
}
